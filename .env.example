# ─────────────────────────────────────────────────────────────
# Stripe Keys — get these from https://dashboard.stripe.com/apikeys
# Use TEST keys (pk_test_... / sk_test_...) for development.
# Switch to LIVE keys (pk_live_... / sk_live_...) for production.
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY

# ─────────────────────────────────────────────────────────────
# Email (SMTP) — Outlook / Office 365
# SMTP_USER = your full email address (e.g. info@ziatow.com)
# SMTP_PASS = your Outlook/Microsoft account password
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@ziatow.com
SMTP_PASS=YOUR_OUTLOOK_PASSWORD

# Server port (default: 3000)
PORT=3000
